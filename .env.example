# 쑥 마을 환경변수 템플릿
# 실제 값은 .env.local에 저장하세요. .env.local은 git에 올라가지 않습니다.
# Vercel 배포 시에는 Vercel 대시보드의 Environment Variables에 동일하게 입력하세요.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 키는 서버 코드에서만 사용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# === Resend (이메일 발송) ===
RESEND_API_KEY=
# 발신 이메일은 Resend에서 도메인 인증 후 사용 가능. 초기엔 onboarding@resend.dev 사용 가능.
RESEND_FROM_EMAIL=onboarding@resend.dev

# === Web Push (VAPID) ===
# 생성 명령: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# === Vercel Cron 보호 ===
# 32바이트 랜덤 문자열. /api/cron/* 라우트가 이 값으로 헤더 검증.
CRON_SECRET=

# === 공공데이터포털 ===
# https://www.data.go.kr 마이페이지에서 발급
PUBLIC_DATA_API_KEY=
